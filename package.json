{
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "@types/node": "^22.10.10",
    "abap-adt-api": "^8.4.1",
    "dotenv": "^16.4.7",
    "typescript": "^5.7.3"
  },
  "name": "mcp-abap-abap-adt-api",
  "version": "0.1.1",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/mcp-server.js",
    "server": "node src/mcp-server.js",
    "build:ts": "tsc -p tsconfig.json",
    "dist:exe": "node scripts/build.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "npx @modelcontextprotocol/inspector ./dist/index.js",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.mcp-abap.adt-api",
    "productName": "MCP ABAP ADT API",
    "directories": {
      "output": "release_build"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "env-schema.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "MCP server for ABAP ADT API integration",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  }
}
